{
    // ── CMake Tools ─────────────────────────────────────────────────
    // CMake Tools reads CMakePresets.json automatically.
    // Select a configure preset via: Ctrl+Shift+P → "CMake: Select Configure Preset"
    "cmake.useCMakePresets": "always",

    // ── C/C++ IntelliSense ──────────────────────────────────────────
    // Use compile_commands.json generated by CMake (enabled by default in base preset).
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",

    // ── File Associations ───────────────────────────────────────────
    "files.associations": {
        "*.mm": "objective-cpp",
        "*.m":  "objective-c",
        "*.metal": "metal",
        "*.msl": "metal",
        "*.glsl": "glsl",
        "*.vert": "glsl",
        "*.frag": "glsl",
        "*.comp": "glsl",
        "*.spv":  "default"
    },

    // ── Search / Explorer Exclusions ────────────────────────────────
    "files.exclude": {
        "build/**": true,
        "cmake-build-*/**": true,
        "**/.DS_Store": true
    },
    "search.exclude": {
        "build/**": true,
        "cmake-build-*/**": true,
        "third-party/**": true,
        "**/compile_commands.json": true
    },

    // ── Editor Defaults ─────────────────────────────────────────────
    "editor.formatOnSave": false,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.rulers": [120],

    // ── clangd (alternative to ms-vscode.cpptools) ──────────────────
    // Uncomment below if using clangd instead of the Microsoft C/C++ extension:
    // "clangd.arguments": [
    //     "--compile-commands-dir=${workspaceFolder}/build/macos-metal-demo",
    //     "--header-insertion=iwyu",
    //     "--clang-tidy"
    // ],

    // ── Terminal Environment ─────────────────────────────────────────
    // Vulkan on macOS requires the Vulkan Loader and MoltenVK ICD.
    // Uncomment and adjust for your system (Apple Silicon paths shown):
    // "terminal.integrated.env.osx": {
    //     "DYLD_LIBRARY_PATH": "/opt/homebrew/lib",
    //     "VK_ICD_FILENAMES": "/opt/homebrew/etc/vulkan/icd.d/MoltenVK_icd.json",
    //     "VK_DRIVER_FILES": "/opt/homebrew/etc/vulkan/icd.d/MoltenVK_icd.json"
    // },

    "cmake.options.statusBarVisibility": "visible"
}
